\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces \textbf  {The Great Divergence (Fig.\nobreakspace  {}A.45).} A single distilled image: seven machine architectures collapse while human perception remains serene. The horizontal axis spans imperceptible perturbations on the left to clearly visible ones on the right. The gap between where machines fail and where humans prevail is the central problem this paper addresses.\relax }}{41}{figure.caption.34}\protected@file@percent }
\newlabel{fig:hero_divergence}{{23}{41}{\textbf {The Great Divergence (Fig.~A.45).} A single distilled image: seven machine architectures collapse while human perception remains serene. The horizontal axis spans imperceptible perturbations on the left to clearly visible ones on the right. The gap between where machines fail and where humans prevail is the central problem this paper addresses.\relax }{figure.caption.34}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces \textbf  {The Collapse Cascade (Fig.\nobreakspace  {}A.46).} Ten CIFAR-10 images (one per class) shown at ten equally-spaced $\varepsilon $ levels. The machine predictions (top labels) go from correct to absurd within the first few rows. Human predictions (bottom labels) remain correct throughout, with confidence naturally decreasing. The disturbing part: to a human, the bottom row still looks like a truck, a horse, a cat.\relax }}{42}{figure.caption.35}\protected@file@percent }
\newlabel{fig:collapse_cascade}{{24}{42}{\textbf {The Collapse Cascade (Fig.~A.46).} Ten CIFAR-10 images (one per class) shown at ten equally-spaced $\varepsilon $ levels. The machine predictions (top labels) go from correct to absurd within the first few rows. Human predictions (bottom labels) remain correct throughout, with confidence naturally decreasing. The disturbing part: to a human, the bottom row still looks like a truck, a horse, a cat.\relax }{figure.caption.35}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces \textbf  {The RHAN Trajectory (Fig.\nobreakspace  {}A.47).} A spacecraft metaphor for progressive architecture hardening. Each RHAN variant is a stage that fires and falls away, pushing the payload (robustness) higher. The clean accuracy sacrifice at each stage is shown as exhaust. The human ceiling glows at $\varepsilon {=}0.30$, still unreached but visibly closer.\relax }}{43}{figure.caption.36}\protected@file@percent }
\newlabel{fig:rhan_trajectory}{{25}{43}{\textbf {The RHAN Trajectory (Fig.~A.47).} A spacecraft metaphor for progressive architecture hardening. Each RHAN variant is a stage that fires and falls away, pushing the payload (robustness) higher. The clean accuracy sacrifice at each stage is shown as exhaust. The human ceiling glows at $\varepsilon {=}0.30$, still unreached but visibly closer.\relax }{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces \textbf  {Class Vulnerability Fingerprints (Fig.\nobreakspace  {}A.48).} Radar charts comparing human and RHAN-trades-curriculum $d'$ at $\varepsilon {=}0.10$. The human fingerprint is large and nearly circular, indicating consistent perceptual sensitivity across all classes. The machine fingerprint is visibly distorted, with automobile and truck collapsed toward the center --- these are the classes the model \textit  {cannot} defend, no matter how hard we train it.\relax }}{44}{figure.caption.37}\protected@file@percent }
\newlabel{fig:vulnerability_fingerprint}{{26}{44}{\textbf {Class Vulnerability Fingerprints (Fig.~A.48).} Radar charts comparing human and RHAN-trades-curriculum $d'$ at $\varepsilon {=}0.10$. The human fingerprint is large and nearly circular, indicating consistent perceptual sensitivity across all classes. The machine fingerprint is visibly distorted, with automobile and truck collapsed toward the center --- these are the classes the model \textit {cannot} defend, no matter how hard we train it.\relax }{figure.caption.37}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces \textbf  {The Confidence Hall of Mirrors (Fig.\nobreakspace  {}A.49).} The same adversarial panda image shown to six architectures. Every model reports $\geq 95\%$ confidence in a wrong answer (gibbon, ostrich, cat, etc.). The human panel shows the correct answer with appropriate uncertainty (62\%). This is the confidence-accuracy dissociation that makes AI failures dangerous: the machine never knows it's wrong.\relax }}{45}{figure.caption.38}\protected@file@percent }
\newlabel{fig:confidence_mirrors}{{27}{45}{\textbf {The Confidence Hall of Mirrors (Fig.~A.49).} The same adversarial panda image shown to six architectures. Every model reports $\geq 95\%$ confidence in a wrong answer (gibbon, ostrich, cat, etc.). The human panel shows the correct answer with appropriate uncertainty (62\%). This is the confidence-accuracy dissociation that makes AI failures dangerous: the machine never knows it's wrong.\relax }{figure.caption.38}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces \textbf  {Latent Space Invasion (Fig.\nobreakspace  {}A.50).} 3D t-SNE projections of the final feature layer. ResNet-18 (left): adversarial perturbations shatter class clusters into dust. RHAN-adv (right): clusters deform under pressure but maintain their identity. The recurrent feedback mechanism acts like a structural frame, keeping the representation from flying apart.\relax }}{45}{figure.caption.39}\protected@file@percent }
\newlabel{fig:latent_invasion}{{28}{45}{\textbf {Latent Space Invasion (Fig.~A.50).} 3D t-SNE projections of the final feature layer. ResNet-18 (left): adversarial perturbations shatter class clusters into dust. RHAN-adv (right): clusters deform under pressure but maintain their identity. The recurrent feedback mechanism acts like a structural frame, keeping the representation from flying apart.\relax }{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces \textbf  {The Feedback Loop in Action (Fig.\nobreakspace  {}A.51).} How RHAN processes a clean image (left) vs.\ an adversarial one (right). The feedback gate (heatmap overlay on the stem) automatically shifts its focus when corruption is detected: suppressing background noise and reinforcing surviving shape features. This is the top-down attention mechanism that makes recurrence robust.\relax }}{46}{figure.caption.40}\protected@file@percent }
\newlabel{fig:feedback_loop}{{29}{46}{\textbf {The Feedback Loop in Action (Fig.~A.51).} How RHAN processes a clean image (left) vs.\ an adversarial one (right). The feedback gate (heatmap overlay on the stem) automatically shifts its focus when corruption is detected: suppressing background noise and reinforcing surviving shape features. This is the top-down attention mechanism that makes recurrence robust.\relax }{figure.caption.40}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces \textbf  {The Resolution Futility (Fig.\nobreakspace  {}A.52).} Increasing resolution 9$\times $ (from $32{\times }32$ to $96{\times }96$) produces virtually no improvement in adversarial robustness. The PGD curves overlap. The car/truck classes collapse to 0\% at $\varepsilon {=}0.031$ on both datasets. More pixels give the attacker more dimensions to exploit. Without architectural changes, resolution is just a bigger target.\relax }}{46}{figure.caption.41}\protected@file@percent }
\newlabel{fig:resolution_futility}{{30}{46}{\textbf {The Resolution Futility (Fig.~A.52).} Increasing resolution 9$\times $ (from $32{\times }32$ to $96{\times }96$) produces virtually no improvement in adversarial robustness. The PGD curves overlap. The car/truck classes collapse to 0\% at $\varepsilon {=}0.031$ on both datasets. More pixels give the attacker more dimensions to exploit. Without architectural changes, resolution is just a bigger target.\relax }{figure.caption.41}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {31}{\ignorespaces \textbf  {AutoAttack Waterfall (Fig.\nobreakspace  {}A.53).} How an ensemble of four attacks progressively reduces RHAN-trades-curriculum accuracy. APGD-CE finds the easy adversarial examples (78\% $\to $ 30\%). APGD-T finds the targeted ones (30\% $\to $ 22\%). FAB-T and SQUARE find nothing new --- the defense is genuine. The flat tail is the most important part: it means the model isn't relying on gradient masking.\relax }}{47}{figure.caption.42}\protected@file@percent }
\newlabel{fig:autoattack_waterfall}{{31}{47}{\textbf {AutoAttack Waterfall (Fig.~A.53).} How an ensemble of four attacks progressively reduces RHAN-trades-curriculum accuracy. APGD-CE finds the easy adversarial examples (78\% $\to $ 30\%). APGD-T finds the targeted ones (30\% $\to $ 22\%). FAB-T and SQUARE find nothing new --- the defense is genuine. The flat tail is the most important part: it means the model isn't relying on gradient masking.\relax }{figure.caption.42}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {32}{\ignorespaces \textbf  {What Humans See vs.\ What Machines See (Fig.\nobreakspace  {}A.54).} The most important figure in the paper. Five images that fool every model. Columns (a) and (b) look identical to humans --- the adversarial perturbation is truly invisible. Column (c) reveals the hidden noise at 50$\times $ amplification. Grad-CAM (d) shows the model attending to the wrong regions. Human eye-tracking (e) shows humans attending to the right ones. Two different worlds, looking at the same image.\relax }}{48}{figure.caption.43}\protected@file@percent }
\newlabel{fig:human_machine_percept}{{32}{48}{\textbf {What Humans See vs.\ What Machines See (Fig.~A.54).} The most important figure in the paper. Five images that fool every model. Columns (a) and (b) look identical to humans --- the adversarial perturbation is truly invisible. Column (c) reveals the hidden noise at 50$\times $ amplification. Grad-CAM (d) shows the model attending to the wrong regions. Human eye-tracking (e) shows humans attending to the right ones. Two different worlds, looking at the same image.\relax }{figure.caption.43}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces \textbf  {The Robustness Spectrum (Fig.\nobreakspace  {}A.55).} Where each system lives on the perturbation tolerance scale. The human bar extends beyond the chart. The gap between RHAN-trades-curriculum (0.185) and the human threshold ($>$0.30) is labeled ``The Final Frontier'' --- the remaining distance to close. Each bar's color shifts from cold (fragile) to warm (robust) across the spectrum.\relax }}{49}{figure.caption.44}\protected@file@percent }
\newlabel{fig:ethresh_spectrum}{{33}{49}{\textbf {The Robustness Spectrum (Fig.~A.55).} Where each system lives on the perturbation tolerance scale. The human bar extends beyond the chart. The gap between RHAN-trades-curriculum (0.185) and the human threshold ($>$0.30) is labeled ``The Final Frontier'' --- the remaining distance to close. Each bar's color shifts from cold (fragile) to warm (robust) across the spectrum.\relax }{figure.caption.44}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces \textbf  {Training Dynamics (Fig.\nobreakspace  {}A.56).} Watching RHAN learn to be robust over 60 epochs of curriculum adversarial training. The model trades clean accuracy (a) for robust accuracy (b). The $d'$ curve (c) crosses the critical $d'{=}1.0$ threshold at epoch 38 --- the moment the model transitions from ``blind'' to ``seeing.'' Gating entropy (d) decreases as the feedback mechanism learns to focus. Three phases: gentle introduction (1--20), increasing pressure (21--40), final hardening (41--60).\relax }}{49}{figure.caption.45}\protected@file@percent }
\newlabel{fig:training_dynamics}{{34}{49}{\textbf {Training Dynamics (Fig.~A.56).} Watching RHAN learn to be robust over 60 epochs of curriculum adversarial training. The model trades clean accuracy (a) for robust accuracy (b). The $d'$ curve (c) crosses the critical $d'{=}1.0$ threshold at epoch 38 --- the moment the model transitions from ``blind'' to ``seeing.'' Gating entropy (d) decreases as the feedback mechanism learns to focus. Three phases: gentle introduction (1--20), increasing pressure (21--40), final hardening (41--60).\relax }{figure.caption.45}{}}
